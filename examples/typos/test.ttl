@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://example.com/typo#> .

# =============================================================================
# Example for ontology-typo-audit skill — multilingual (en/es/de/fr)
# Issues:
#   1. @es "Pista de Padel" — missing accent: "Pista de Pádel"
#   2. @es "Lampara de calle" — missing accent: "Lámpara"
#   3. @de "Strassenlaterne" — missing ß: "Straßenlaterne"
#   4. @de "Fahrradstaender" — should be "Fahrradständer" (ä not ae in this context - actually in Swiss German ae is OK, but in de-DE it should be ä)
#   5. @fr "Arrêt de buse" — extra 'e': "Arrêt de bus"
#   6. @en "pubic transport" — typo: "public transport"
#   7. @es "The bus stop" — English text tagged @es (lang tag mismatch)
#   8. @fr correct items — no issues
#   9. @de correct items — no issues
# =============================================================================

:StreetLamp a skos:Concept ;
    skos:prefLabel "Street Lamp"@en ;
    skos:prefLabel "Lampara de calle"@es ;           # ← Lámpara
    skos:prefLabel "Strassenlaterne"@de ;            # ← Straßenlaterne
    skos:definition "Una lampara en la via publica"@es .  # ← 2 accent errors

:PadelCourt a skos:Concept ;
    skos:prefLabel "Padel Court"@en ;
    skos:prefLabel "Pista de Padel"@es .             # ← Pádel

:Transport a skos:Concept ;
    skos:prefLabel "pubic transport"@en ;            # ← public
    skos:prefLabel "The bus stop"@es ;               # ← English @es — mismatch
    skos:prefLabel "Öffentlicher Verkehr"@de .       # ← correct

:BikeRack a skos:Concept ;
    skos:prefLabel "Bicycle Rack"@en ;
    skos:prefLabel "Fahrradstaender"@de ;            # ← Fahrradständer
    skos:prefLabel "Arrêt de buse"@fr .             # ← Arrêt de bus

:HealthCenter a skos:Concept ;
    skos:prefLabel "Health Center"@en ;
    skos:prefLabel "Centro de Salud"@es ;            # ← correct
    skos:prefLabel "Gesundheitszentrum"@de ;         # ← correct
    skos:prefLabel "Centre de santé"@fr .            # ← correct
