@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.com/langcov#> .

# =============================================================================
# Example for ontology-lang-coverage skill
# Demonstrates a trilingual project (en/de/fr) with missing translations.
# Issues:
#   1. :StreetLamp — has @en, @de but missing @fr
#   2. :ParkingMeter — has @de only
#   3. :BusStop — complete in all 3 languages
#   4. :BicycleRack — has @es (outside expected en/de/fr set)
# =============================================================================

: a owl:Ontology ;
    rdfs:label "Language Coverage Test"@en ;
    rdfs:label "Sprachabdeckungstest"@de ;
    rdfs:label "Test de couverture linguistique"@fr .

# Missing @fr
:StreetLamp a owl:Class ;
    rdfs:label "Street Lamp"@en ;
    rdfs:label "Straßenlaterne"@de ;
    rdfs:comment "Illuminates streets at night"@en .

# Only @de
:ParkingMeter a owl:Class ;
    rdfs:label "Parkscheinautomat"@de ;
    rdfs:comment "Automat für Parkgebühren"@de .

# Complete (3 languages)
:BusStop a owl:Class ;
    rdfs:label "Bus Stop"@en ;
    rdfs:label "Bushaltestelle"@de ;
    rdfs:label "Arrêt de bus"@fr .

# Extra language (@es outside en/de/fr)
:BicycleRack a owl:Class ;
    rdfs:label "Bicycle Rack"@en ;
    rdfs:label "Fahrradständer"@de ;
    rdfs:label "Aparcamiento de bicicletas"@es .
