@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.com/vocabaudit#> .

# =============================================================================
# Example for ontology-vocab-audit skill
# Issues demonstrated:
#   1. owl:imports a URI that does NOT resolve (P37 in OOPS terms)
#   2. Local property :label reinvents rdfs:label
#   3. Local property :sameAs reinvents owl:sameAs
#   4. Uses a namespace http://foo.invalid/ that won't resolve
# =============================================================================

: a owl:Ontology ;
    owl:imports <http://this-does-not-exist.example.com/nope.owl> .

# BAD: local :label instead of rdfs:label
:label a owl:AnnotationProperty .

# BAD: local :sameAs instead of owl:sameAs
:sameAs a owl:ObjectProperty .

# Uses an unresolvable external namespace
<http://foo.invalid/ns#SomeClass> a owl:Class ;
    rdfs:label "From broken namespace"@en .

:MyClass a owl:Class ;
    :label "My Label"@en ;            # should be rdfs:label
    :sameAs <http://example.com/other> .  # should be owl:sameAs
